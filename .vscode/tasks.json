{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build MyBrowserShell",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/MyBrowserShell/MyBrowserShell.csproj"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "run MyBrowserShell",
            "type": "shell",
            "command": "${workspaceFolder}/run.bat",
            "dependsOn": "build MyBrowserShell",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
